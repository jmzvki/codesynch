{
    "identifier": "zvkifa.CodeSynch",
    "name": "CodeSynch",
    "organization": "Zavocki Fine Arts LLC",
    "description": "AI-powered code synthesis for Nova. Write methods, generate protocols, and explode abstractions — powered by Claude or ChatGPT.",
    "version": "0.1.0",
    "categories": ["commands"],

    "main": "main.js",

    "activationEvents": ["*"],

    "entitlements": {
        "requests": true,
        "clipboard": true
    },

    "config": [
        {
            "title": "Claude API Key",
            "key": "codesynch.claudeApiKey",
            "type": "string",
            "placeholder": "sk-ant-...",
            "description": "Your Anthropic API key. Get one at console.anthropic.com"
        },
        {
            "title": "Claude Model",
            "key": "codesynch.claudeModel",
            "type": "enum",
            "values": [
                ["claude-opus-4-5", "Claude Opus 4.5 (most capable)"],
                ["claude-sonnet-4-5", "Claude Sonnet 4.5 (balanced)"],
                ["claude-haiku-4-5-20251001", "Claude Haiku 4.5 (fast)"]
            ],
            "default": "claude-sonnet-4-5"
        },
        {
            "title": "OpenAI API Key",
            "key": "codesynch.openaiApiKey",
            "type": "string",
            "placeholder": "sk-...",
            "description": "Your OpenAI API key. Get one at platform.openai.com"
        },
        {
            "title": "OpenAI Model",
            "key": "codesynch.openaiModel",
            "type": "enum",
            "values": [
                ["gpt-4o", "GPT-4o"],
                ["gpt-4o-mini", "GPT-4o mini"]
            ],
            "default": "gpt-4o"
        },
        {
            "title": "Comment Density",
            "key": "codesynch.commentDensity",
            "type": "enum",
            "values": [
                ["auto", "Auto (based on complexity)"],
                ["always", "Always comment"],
                ["never", "Never comment"]
            ],
            "default": "auto"
        }
    ],

    "commands": {
        "editor": [
            {
                "title": "Write / Implement",
                "command": "codesynch.write",
                "shortcut": "opt-shift-w",
                "when": "editorHasFocus"
            },
            {
                "title": "Explode / Abstract",
                "command": "codesynch.explode",
                "shortcut": "opt-shift-e",
                "when": "editorHasFocus"
            },
            {
                "separator": true
            },
            {
                "title": "Refactor",
                "command": "codesynch.refactor",
                "shortcut": "opt-shift-r",
                "when": "editorHasFocus"
            },
            {
                "separator": true
            },
            {
                "title": "Generate Protocol / Interface",
                "command": "codesynch.protocol",
                "shortcut": "opt-shift-p",
                "when": "editorHasFocus"
            },
            {
                "title": "Explain Selection",
                "command": "codesynch.explain",
                "shortcut": "opt-shift-x",
                "when": "editorHasFocus"
            }
        ]
    }
}